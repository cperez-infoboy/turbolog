# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# JWT
JWT_SECRET=long-random-string-32-chars-min
JWT_EXPIRE_HOURS=24

# Database
DATABASE_URL=sqlite+aiosqlite:///./turbolog.db

# App
APP_URL=http://localhost:5173

# JIRA (global admin token)
JIRA_EMAIL=admin@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_CACHE_TTL=300
JIRA_REQUEST_TIMEOUT=10

# Configuración modelo LLM
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash



# Auditoria / recordatorios
REMINDER_TIME=17:30
AUDIT_TIMEZONE=America/Argentina/Buenos_Aires
ADMIN_EMAILS=admin@yourcompany.com,lead@yourcompany.com
NOTIFIER_MODE=log
ENABLE_SCHEDULER=true
